<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="page-main">
  <div class="page-header">
    <h1>Topic Statistics</h1>
    <p class="subtitle">Access counts tracked via Observer pattern</p>
  </div>

  <%- include('partials/flash') %>

  <div class="stats-summary">
    <div class="stat-card">
      <span class="stat-num"><%= topics.length %></span>
      <span class="stat-label">Total Topics</span>
    </div>
    <div class="stat-card">
      <span class="stat-num"><%= myMessageCount %></span>
      <span class="stat-label">My Messages Posted</span>
    </div>
  </div>

  <div class="stats-table-wrapper">
    <table class="stats-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Topic</th>
          <th>Created By</th>
          <th>Created</th>
          <th>Access Count</th>
          <th>Bar</th>
        </tr>
      </thead>
      <tbody>
        <% const maxAccess = topics.length > 0 ? Math.max(...topics.map(t => t.accessCount), 1) : 1; %>
        <% topics.forEach((topic, i) => { %>
          <tr>
            <td class="rank"><%= i + 1 %></td>
            <td><a href="/topics/<%= topic._id %>" class="topic-link"><%= topic.title %></a></td>
            <td class="muted">@<%= topic.createdBy.username %></td>
            <td class="muted"><%= topic.createdAt.toLocaleDateString() %></td>
            <td class="count-cell"><%= topic.accessCount %></td>
            <td class="bar-cell">
              <div class="bar-bg">
                <div class="bar-fill" style="width: <%= Math.round((topic.accessCount / maxAccess) * 100) %>%"></div>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('partials/footer') %
