<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="auth-main">
  <div class="auth-card">
    <h1 class="auth-title">Sign In</h1>
    <p class="auth-sub">Welcome back to ThreadBoard</p>
    <%- include('../partials/flash') %>
    <form action="/login" method="POST" class="auth-form">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" required autocomplete="username" placeholder="your_handle">
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" required autocomplete="current-password" placeholder="••••••••">
      </div>
      <button type="submit" class="btn-primary full-width">Log In →</button>
    </form>
    <p class="auth-switch">No account? <a href="/register">Register here</a></p>
  </div>
</main>

<%- include('../partials/footer') %>
