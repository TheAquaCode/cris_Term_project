<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="auth-main">
  <div class="auth-card wide-card">
    <h1 class="auth-title">Start a New Topic</h1>
    <p class="auth-sub">You'll be auto-subscribed to your new topic</p>
    <%- include('../partials/flash') %>
    <form action="/topics/new" method="POST" class="auth-form">
      <div class="form-group">
        <label>Topic Title <span class="required">*</span></label>
        <input type="text" name="title" required placeholder="e.g. Best Linux distros for gaming">
      </div>
      <div class="form-group">
        <label>Description <span class="optional">(optional)</span></label>
        <textarea name="description" rows="3" placeholder="What is this topic about?"></textarea>
      </div>
      <div class="form-row">
        <a href="/dashboard" class="btn-secondary">Cancel</a>
        <button type="submit" class="btn-primary">Create Topic →</button>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
